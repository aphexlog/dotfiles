{
  // ========================================================================
  // Zed Editor Configuration
  // ========================================================================

  // ========================================================================
  // Agent / AI Settings
  // ========================================================================
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "default_model": { "provider": "copilot_chat", "model": "gpt-4.1" },
    "favorite_models": [],
    "model_parameters": []
  },

  // ========================================================================
  // Privacy
  // ========================================================================
  "telemetry": { "diagnostics": false },

  // ========================================================================
  // Appearance
  // ========================================================================
  "theme": "Catppuccin Mocha - No Italics",
  "ui_font_size": 16,
  "buffer_font_size": 14,
  "buffer_line_height": { "custom": 1.3 },

  // ========================================================================
  // Editor Behavior
  // ========================================================================
  "base_keymap": "VSCode",
  "vim_mode": true,
  "current_line_highlight": "line",
  
  // Tabs
  "tab_bar": { "show": true },
  "preview_tabs": {
    "enabled": true,
    "enable_preview_from_file_finder": false,
    "enable_keep_preview_on_code_navigation": false
  },

  // Layout
  "centered_layout": { 
    "left_padding": 0.1, 
    "right_padding": 0.1 
  },

  // Scrollbar
  "scrollbar": {
    "show": "never",
    "cursors": false,
    "git_diff": true,
    "search_results": true,
    "selected_symbol": true,
    "diagnostics": "all"
  },

  // ========================================================================
  // Git Integration
  // ========================================================================
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": { "enabled": false }
  },

  // ========================================================================
  // Jupyter Integration
  // ========================================================================
  "jupyter": {
    "kernel_selections": {
      "python": "conda-env",
      "typescript": "node",
      "javascript": "node",
      "r": "ark"
    }
  },

  // ========================================================================
  // Language-Specific Settings
  // ========================================================================
  "languages": {
    "Python": { 
      "language_servers": ["pylsp", "ruff"], 
      "format_on_save": "on" 
    },
    "typescript": {
      "language_servers": ["tsserver", "prettier", "!eslint"],
      "format_on_save": "on"
    },
    "typescriptreact": {
      "language_servers": ["tsserver", "prettier", "!eslint"],
      "format_on_save": "on"
    },
    "javascriptreact": {
      "language_servers": ["tsserver", "prettier", "!eslint"],
      "format_on_save": "on"
    },
    "javascript": {
      "language_servers": ["tsserver", "prettier", "!eslint"],
      "format_on_save": "on"
    },
    "html": {
      "language_servers": ["tsserver", "prettier", "!eslint"],
      "format_on_save": "on"
    }
  },

  // ========================================================================
  // LSP Configuration
  // ========================================================================
  "lsp": {
    "pylsp": {
      "settings": {
        "pylsp.plugins.pylsp_django": { "enabled": true },
        "pylsp.plugins.jedi_completion": { "include_params": true }
      }
    },
    "ruff": { 
      "initialization_options": { "settings": {} } 
    }
  }
}
