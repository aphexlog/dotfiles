{
  "$schema": "https://opencode.ai/config.json",

  "instructions": ["~/.config/opencode/instructions/commit-style.md"],

  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "headers": {}
    },
    "awslabs-aws-documentation-mcp-server": {
      "type": "local",
      "command": ["uvx", "awslabs.aws-documentation-mcp-server@latest"],
      "env": {
        "FASTMCP_LOG_LEVEL": "ERROR",
        "AWS_DOCUMENTATION_PARTITION": "aws"
      }
    },
    "serena": {
      "type": "local",
      "command": ["uvx", "--from", "git+https://github.com/oraios/serena", "serena", "start-mcp-server", "--enable-web-dashboard", "false"],
      "env": {}
    },
    "playwright": {
      "type": "local",
      "command": ["npx", "@playwright/mcp@latest"],
      "env": {}
    },
    "ai-humanizer": {
      "type": "local",
      "command": ["npx", "-y", "ai-humanizer-mcp-server"],
      "env": {}
    },
    "spec-kit": {
      "type": "local",
      "command": ["npx", "-y", "@anyicode/spec-kit-mcp@latest"],
      "env": {}
    }
  }
}
